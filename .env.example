# Servidor de desarrollo (server.js)
PORT=3000

# Firebase — copia los valores a js/firebase-config.js (no subas claves reales al repo)
# Consola Firebase → Configuración del proyecto → Tus apps → SDK web
FIREBASE_API_KEY=TU_API_KEY
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Sentry — errores del servidor Node (opcional; el cliente usa js/sentry-config.js)
SENTRY_DSN=
